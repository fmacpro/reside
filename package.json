{
  "name": "reside",
  "version": "0.1.0",
  "description": "A simplified Node.js-based agentic IDE for local LLMs via Ollama",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "reside": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test test/*.test.js",
    "test:watch": "node --test --watch test/*.test.js"
  },
  "keywords": [
    "agentic",
    "ide",
    "ollama",
    "qwen",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "diff": "^9.0.0",
    "puppeteer": "^24.42.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
